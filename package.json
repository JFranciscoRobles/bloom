{
  "name": "bloom",
  "version": "1.1.3",
  "description": "Bloom — productividad personal: kanban, gantt y finanzas multi-moneda",
  "main": "out/main/index.js",
  "author": "jfrankrobles",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win --x64",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "icon": "node scripts/generate-icon.mjs",
    "seed": "electron scripts/seed.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dayjs": "^1.11.13",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.5",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.451.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.13",
    "to-ico": "^1.1.5",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "zustand": "^4.5.5"
  },
  "build": {
    "appId": "com.jfrankrobles.bloom",
    "productName": "Bloom",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "build/tray-icon.png",
      "build/tray-icon@1x.png",
      "package.json"
    ],
    "extraResources": [
      "build/tray-icon.png",
      "build/tray-icon@1x.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "JFranciscoRobles",
      "repo": "bloom",
      "releaseType": "release"
    }
  }
}